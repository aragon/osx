default: help

import 'lib/just-foundry/justfile'

DEPLOY_SCRIPT := "script/DeployMemberRegistry.s.sol:DeployMemberRegistry"

# Export the MemberRegistry ABI as a TypeScript file under artifacts/
[group('build')]
export-abi:
    #!/usr/bin/env bash
    set -euo pipefail
    forge build --quiet
    mkdir -p artifacts
    {
        echo "// Auto-generated by: just export-abi"
        echo "// Do not edit manually."
        echo ""
        echo -n "export const memberRegistryAbi = "
        jq -c '.abi' out/MemberRegistry.sol/MemberRegistry.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin), indent=2))" | head -c -1
        echo " as const;"
    } > artifacts/MemberRegistry.ts
    echo "Exported to artifacts/MemberRegistry.ts"
