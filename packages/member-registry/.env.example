# Copy to .env and fill in your secrets.
# Network configuration (RPC URL, chain ID, contract addresses) is managed by just-foundry:
#   just switch <network>   — activate a network (e.g. sepolia, mainnet, ...)
#   just env                — show resolved values and their sources

# Required for deployment
# DEPLOYER_KEY=

# Required for contract verification (when VERIFIER=etherscan)
# ETHERSCAN_API_KEY=

# Required for fork tests, override the defaults from just-foundry
# RPC_URL=

# --- MemberRegistry deployment parameters ---

# The management DAO address (manages the registry)
MANAGEMENT_DAO=0xf2d594F3C93C19D7B1a6F15B5489FFcE4B01f7dA

# ENS registry address (0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e on mainnet)
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e

# Parent domain the registry will manage (dot-separated, e.g., "members.dao.eth")
# The script computes the namehash automatically.
# PARENT_DOMAIN=members.dao.eth

# PublicResolver address (must support per-node approve)
# Mainnet: 0x231b0Ee14048e9dCcD1d247744d114a4EB5E8E63
# Note: the v0.0.19 deployment JSON lists 0x2261... but that contract on mainnet
# does NOT have isApprovedFor/approve. Use 0x231b... (confirmed via fork test).
RESOLVER=0x231b0Ee14048e9dCcD1d247744d114a4EB5E8E63
