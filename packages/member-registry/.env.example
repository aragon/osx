# MemberRegistry deployment parameters
# Copy to .env and fill in values for the target network.

# The managing DAO address (grants permissions on both contracts)
MANAGING_DAO=

# ENS registry address (0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e on mainnet)
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e

# Namehash of the parent domain the registrar will manage (bytes32, hex)
# e.g., namehash("members.dao.eth")
PARENT_NODE=

# PublicResolver address (must support per-node approve — ens-contracts >= v0.0.19)
RESOLVER=0x226159d592E2b063810a10Ebf6dcbADA94Ed68b8
